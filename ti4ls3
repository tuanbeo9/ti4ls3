local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Delta X | Full Teleport V3",
   LoadingTitle = "Đang đồng bộ Workspace...",
   LoadingSubtitle = "By Gemini",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Teleport List", 4483362458)

-- Hàm dịch chuyển an toàn
local function TeleportTo(target, displayName)
    if target then
        local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local targetPos = target:IsA("Model") and target:GetModelCFrame() or target.CFrame
            hrp.CFrame = targetPos * CFrame.new(0, 5, 0)
            Rayfield:Notify({
                Title = "Thành công",
                Content = "Đã đến: " .. displayName,
                Duration = 2
            })
        end
    else
        Rayfield:Notify({
            Title = "Lỗi đường dẫn",
            Content = "Không tìm thấy " .. displayName .. ". Có thể game đã update index.",
            Duration = 4
        })
    end
end

